# IRCE Environment Configuration
# Copy this file to .env and fill in your actual values for HF Spaces deployment

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here

# API Configuration
API_BASE_URL=https://api.openai.com/v1
# Or for Hugging Face Inference API:
# API_BASE_URL=https://router.huggingface.co/v1

# Model Configuration
MODEL_NAME=gpt-4o
# Alternative models:
# MODEL_NAME=deepseek-ai/DeepSeek-V3-0324
# MODEL_NAME=gemini-2.5-flash

# Hugging Face Token (required for HF models and Spaces)
HF_TOKEN=hf_your-huggingface-token-here

# IRCE Server Configuration (optional, defaults to 7860 for HF Spaces)
IRCE_HOST=0.0.0.0
IRCE_PORT=7860
IRCE_RELOAD=false
